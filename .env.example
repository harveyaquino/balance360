# Copiar a .env.local - NUNCA commitear con valores reales
# En Vercel: Settings > Environment Variables

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-reemplazar
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FALLBACKS=claude-3-7-sonnet-20250219

# Supabase (claves publicas - seguras en frontend)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu-anon-key

# Supabase (solo backend)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...solo-en-backend

# Seguridad API
ALLOWED_ORIGIN=https://balance360.vercel.app
STRICT_CORS=true
REQUIRE_AUTH_ANALYZE=true
RATE_LIMIT_MAX=12
SIGNALS_FETCH_TIMEOUT_MS=9000

# Fuentes externas
GOOGLE_MAPS_API_KEY=tu-google-maps-key
SERPAPI_API_KEY=tu-serpapi-key
